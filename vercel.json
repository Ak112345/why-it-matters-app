{
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm run dev",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/content/generate",
      "schedule": "0 6,14,22 * * *"
    },
    {
      "path": "/api/produce",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/publish/cron",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/queue/archive-posted",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/tokens/monitor",
      "schedule": "0 8 * * *"
    }
  ],
  "build": {
    "env": {
      "VERCEL_IGNORE_ESLINT": "true"
    }
  }
}